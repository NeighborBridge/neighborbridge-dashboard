# Phase 1A Email-to-Dashboard — Dry Run
# ======================================
# Copy this file to .env and fill in your forwarding mailbox credentials.
#
# ⚠️ SECURITY: Never commit .env to git. It is already excluded by this file's instructions.
# The .env file should live beside email_dryrun.py, not in the repo root.
#
# --- Required ---
# Email address of the dedicated forwarding inbox
# (Richard manually forwards selected emails here. No automatic forwarding rules.)
FORWARDING_EMAIL=nb-inbox@gmail.com

# Gmail App Password (16-character, generated from Google Account → Security → App Passwords)
# Scope: "Mail" only. Read-only is sufficient for Phase 1A.
FORWARDING_APP_PASSWORD=aaaa bbbb cccc dddd

# IMAP server (Gmail)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# --- Optional ---
# Maximum emails to process per run (dry run default: 10)
MAX_EMAILS=10

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Auto-cleanup: remove draft .txt and JSON logs older than this many days
# Default: 7 (Phase 1A artifacts are temporary by design)
RETENTION_DAYS=7
